<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:VAMedicalCallClient.ViewModels"
        x:Class="VAMedicalCallClient.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{StaticResource APPTitle}"
        Height="600" Width="900"
        Icon="/Assets/app-logo.ico"
        WindowStartupLocation="CenterScreen"
        WindowState="Maximized"> 

        <Window.Styles>
            <!-- Если панель SplitView ЗАКРЫТА, скрываем текст в кнопках меню -->
            <Style Selector="SplitView[IsPaneOpen=False] TextBlock.menu-text">
                <Setter Property="IsVisible" Value="False"/>
            </Style>

            <!-- Если панель SplitView ОТКРЫТА, показываем текст -->
            <Style Selector="SplitView[IsPaneOpen=True] TextBlock.menu-text">
                <Setter Property="IsVisible" Value="True"/>
            </Style>

            <!-- Стилизация навигационных кнопок -->
            <Style Selector="StackPanel.menu-container Button">
                <Setter Property="Padding" Value="12,10"/>
                <Setter Property="Background" Value="Transparent"/>
                <Setter Property="HorizontalAlignment" Value="Stretch"/>
                <Setter Property="HorizontalContentAlignment" Value="Left"/>
            </Style>

            <!-- Адаптивный цвет иконкам и тексту в меню -->
            <Style Selector="StackPanel.menu-container PathIcon">
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            </Style>
            <Style Selector="StackPanel.menu-container TextBlock">
                <Setter Property="Foreground" Value="{DynamicResource SystemControlForegroundBaseHighBrush}"/>
            </Style>
        </Window.Styles>

    <!-- Корневой элемент — SplitView (занимает всё пространство) -->
    <SplitView x:Name="MainMenuSplitView"
               IsPaneOpen="{Binding IsPaneOpen}"
               DisplayMode="CompactInline"
               OpenPaneLength="220"
               CompactPaneLength="50"
               Background="{DynamicResource SystemRegionBrush}"
               PaneBackground="{DynamicResource SystemControlTransientBackgroundBrush}">

        <!-- Содержимое боковой панели (Гамбургер-меню) -->
        <SplitView.Pane>
            <Grid RowDefinitions="*, Auto" Margin="0,5,0,5">

                <!-- Верхняя часть меню (Навигация) -->
                <StackPanel Grid.Row="0" Classes="menu-container" Spacing="5">
                    <!-- Кнопка триггера гамбургера -->
                    <Button Command="{Binding TogglePane}"
                            Width="40" Height="40" Margin="5,0,5,15"
                            HorizontalAlignment="Left" HorizontalContentAlignment="Center" VerticalContentAlignment="Center">
                        <PathIcon Data="M2 5h20v2H2zm0 6h20v2H2zm0 6h20v2H2z" Width="18" Height="18"/>
                    </Button>

                    <!-- Элемент навигации 1: Заявки (Calls) -->
                    <Button Command="{Binding NavigateToCalls}">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="/Assets/calls.png" Width="20" Height="20"/>
                            <TextBlock Text="Заявки" Classes="menu-text" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <!-- Элемент навигации 2: Медицинские бригады (Brigades) -->
                    <Button Command="{Binding NavigateToBrigades}">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="/Assets/brigades.png" Width="20" Height="20"/>
                            <TextBlock Text="Бригады" Classes="menu-text" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

                <!-- Нижняя часть меню (Сведения и Выход) -->
                <StackPanel Grid.Row="1" Classes="menu-container" Spacing="5">
                    <!-- Элемент: Сведения (Information) -->
                    <Button Command="{Binding ShowAboutWindow}">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="/Assets/info.png" Width="20" Height="20"/>                            
                                      
                            <TextBlock Text="Сведения" Classes="menu-text" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>

                    <Button Command="{Binding #}">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <Image Source="/Assets/options.png" Width="20" Height="20"/>                            
                                      
                            <TextBlock Text="Настройка" Classes="menu-text" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>


                    <!-- Кнопка Выхода -->
                    <Button Command="{Binding ExitApp}">
                        <StackPanel Orientation="Horizontal" Spacing="15">
                            <PathIcon Data="M10.09 15.59L11.5 17l5-5-5-5-1.41 1.41L13.17 11H3v2h10.17l-3.08 3.59zM19 3H5c-1.1 0-2 .9-2 2v4h2V5h14v14H5v-4H3v4c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2z"
                                      Width="16" Height="16" Foreground="#D32F2F"/>
                            <TextBlock Text="Выход" Classes="menu-text" VerticalAlignment="Center" Foreground="#D32F2F"/>
                        </StackPanel>
                    </Button>
                </StackPanel>

            </Grid>
        </SplitView.Pane>

        <!-- Главная рабочая область — занимает всё оставшееся пространство экрана -->
        <Grid RowDefinitions="Auto, *" HorizontalAlignment="Stretch" VerticalAlignment="Stretch">
            <Border Grid.Row="0"
                    Background="#4BB462"
                    CornerRadius="6"
                    Padding="18,12"
                    Margin="0,0,0,12">

                <StackPanel Orientation="Vertical" Spacing="4">
                    <TextBlock Text="{Binding CurrentModuleTitle, StringFormat='МедВызов: {0}'}"
                               FontSize="20"
                               FontWeight="SemiBold"
                               Foreground="White"
                               HorizontalAlignment="Center"/>

                    <TextBlock Text="{Binding CurrentModuleSubTitle}"
                               FontSize="14"
                               FontWeight="Normal"
                               Foreground="#E0F2E9"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Border>

            <!-- Динамический контент клиентских модулей во весь экран -->
            <TransitioningContentControl Grid.Row="1"
                                         Content="{Binding Router.CurrentViewModel^}"
                                         HorizontalAlignment="Stretch"
                                         VerticalAlignment="Stretch"
                                         HorizontalContentAlignment="Stretch"
                                         VerticalContentAlignment="Stretch">
                <TransitioningContentControl.PageTransition>
                    <CrossFade Duration="0:0:0.2" />
                </TransitioningContentControl.PageTransition>
            </TransitioningContentControl>
        </Grid>

    </SplitView>
</Window>
