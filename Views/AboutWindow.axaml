<Window xmlns="https://github.com/avaloniaui"
		xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
		xmlns:vm="using:VAMedicalCallClient.ViewModels"
		x:Class="VAMedicalCallClient.Views.AboutWindow"		
		x:DataType="vm:AboutWindowViewModel"
		Title="{StaticResource APPTitle}"
		Width="450"
		Height="380"
		WindowStartupLocation="CenterOwner"
		CanMinimize="False"
		CanResize="False">

	<Design.DataContext>
		<vm:AboutWindowViewModel/>
	</Design.DataContext>

	<Window.Styles>
		<Style Selector="TextBlock.email:pointerover">
			<Setter Property="Background" Value="#F0F8FF"/>
			<Setter Property="Cursor" Value="Hand"/>
		</Style>
	</Window.Styles>

	<Grid RowDefinitions="Auto,*,Auto" Margin="20">

		<StackPanel Grid.Row="0" Spacing="10">
			<TextBlock Text="О ПРОГРАММЕ"
					   FontSize="18"
					   FontWeight="Bold"/>
			<Border  BorderBrush="Gray" BorderThickness="1" >
			</Border>
		</StackPanel>

		<Grid Grid.Row="1" ColumnDefinitions="Auto,*" Margin="0,20,0,20">

			<!-- APP Logo -->
			<Rectangle Grid.Column="0" Fill="#4BB462" Width="220"/>

			<Image  Width="200"
					Height="165"
					Source="/Assets/about.png"
					Stretch="Uniform"
					VerticalAlignment="Center"/>

			<!-- APP info -->
			<StackPanel Grid.Column="1" Margin="10,0,0,0"
						VerticalAlignment="Top"
						HorizontalAlignment="Center">

				<!-- App Name -->
				<TextBlock FontSize="28"
						   FontWeight="Bold"
						   HorizontalAlignment="Center">
					<Run Foreground="#FF0000">Мед</Run>
					<Run Foreground="#00CF91">Вызов</Run>
				</TextBlock>

				<!-- App Version -->
				<TextBlock Text="{Binding MajorVersion}"
						   HorizontalAlignment="Center"
						   FontWeight="Bold"
						   FontSize="14"
						   Margin="0,10,0,5"/>

				<TextBlock Text="{Binding BuildVersion}"
						   HorizontalAlignment="Center"
						   FontSize="12"
						   Opacity="0.7"
						   Margin="0,0,0,0"/>

				<TextBlock Text="C# Avalonia ReactiveUI MVVM "
						   HorizontalAlignment="Center"
						   FontSize="10"
						   Opacity="0.7"
						   Margin="0,0,0,15"/>



				<!-- App Description -->
				<TextBlock Text="{StaticResource APPDescription}"
						   HorizontalAlignment="Center"
						   TextAlignment="Center"
						   FontSize="14"
						   TextWrapping="Wrap"/>

				<TextBlock Text="{Binding DeveloperEmail}"
						   Classes="email"
						   HorizontalAlignment="Center"
						   VerticalAlignment="Center"
						   FontSize="12"
						   Margin="0,10,0,0"/>


		</StackPanel>
		</Grid>

		<!-- Close Button -->
		<Border Grid.Row="2"
				BorderBrush="{DynamicResource SystemControlBackgroundBaseLowBrush}"
				BorderThickness="0,1,0,0"
				Padding="0,15,0,0">
			<Button Grid.Row="2" Grid.Column="0" Grid.ColumnSpan="2"
					Content="OK"
					Width="95"
					IsDefault="True"
					Command="{Binding CloseWindowCommand}"
					HorizontalContentAlignment="Center"
					HorizontalAlignment="Right"
					VerticalAlignment="Bottom"/>

		</Border>
	</Grid>

</Window>
